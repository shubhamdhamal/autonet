# Application
APP_NAME=NOC Network Quality Monitoring API
API_PREFIX=/api/v1

# Database (SQLite default; switch to PostgreSQL by updating DATABASE_URL)
DATABASE_URL=sqlite:///./database/noc.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/noc_db

# Monitoring
MONITOR_INTERVAL_SECONDS=30
MONITOR_PROBE_COUNT=4
MONITOR_TIMEOUT_SECONDS=1.0

# Frontend (local dev)
VITE_API_BASE_URL=http://localhost:8000/api/v1
